<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-white flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

  <main class="w-full flex flex-col items-center pb-16 flex-grow bg-white">
  <!-- Banner: campaña vigente hoy (mismo criterio que reservas) -->
  <div class="w-full max-w-7xl mx-auto mt-6 px-4 sm:px-6 lg:px-8">
    <div class="w-full overflow-hidden border border-gray-100 md:rounded-lg bg-white">
      <% if (typeof catalogoBannerUrl === 'string' && catalogoBannerUrl) { %>
        <img src="<%= catalogoBannerUrl %>" alt="Banner: <%= typeof nombreCampañaActiva !== 'undefined' ? nombreCampañaActiva : 'Campaña' %>" class="w-full h-auto object-cover" />
      <% } else { %>
        <div class="w-full min-h-[120px] flex items-center justify-center text-gray-500 px-4 py-8 text-sm md:text-base text-center">
          <span class="font-medium text-gray-700"><%= typeof nombreCampañaActiva !== 'undefined' ? nombreCampañaActiva : 'Campaña activa' %></span>
        </div>
      <% } %>
    </div>
    <% if (typeof idCampanaActiva !== 'undefined' && idCampanaActiva) { %>
    <div class="mt-3 flex justify-end">
      <a href="/empleado/campanas/<%= encodeURIComponent(String(idCampanaActiva)) %>/editar" class="inline-flex items-center bg-white border border-[#007185] text-[#007185] hover:bg-gray-50 px-4 py-2 rounded-md text-sm font-medium transition-colors shadow-sm">
        <span class="material-icons text-[18px] mr-2">edit</span> Editar banner
      </a>
    </div>
    <% } %>
  </div>
  <!-- Cuenta atrás hasta fin de preventa (fecha fin de campaña activa) -->
  <div class="w-full flex flex-col items-center py-6 bg-white">
    <%- include('../partials/catalogo-preventa-contador') %>
  </div>

  <!-- Contenedor Principal (Filtros + Grid de Productos) -->
  <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row gap-6">
    
    <!-- Sidebar de Filtros -->
    <aside class="w-full md:w-64 flex-shrink-0">
      <div class="bg-white p-5 rounded-lg border border-gray-200 sticky top-4">
        <h2 class="text-lg font-bold mb-4 text-gray-900 border-b pb-2">Filtros</h2>
        
        <!-- Artículos -->
        <div class="mb-6">
          <h3 class="font-semibold text-gray-800 mb-3">Unidad</h3>
          <div class="space-y-2">
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="rollo" data-filter-group="unidad" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Rollos</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="kit" data-filter-group="unidad" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Kits</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="cubeta" data-filter-group="unidad" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Cubetas / Galones</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="pieza" data-filter-group="unidad" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Piezas</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="caja" data-filter-group="unidad" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Cajas</span>
            </label>
          </div>
        </div>

        <!-- Categorías -->
        <div>
          <h3 class="font-semibold text-gray-800 mb-3">Tipo de producto</h3>
          <div class="space-y-2">
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="pintura" data-filter-group="categoria" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Pinturas</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="cepillo" data-filter-group="categoria" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Cepillos</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="recubrimiento" data-filter-group="categoria" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Recubrimientos</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="esmalte" data-filter-group="categoria" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Esmaltes</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="limpiador" data-filter-group="categoria" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Limpiadores</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" value="sellador" data-filter-group="categoria" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Selladores</span>
            </label>
          </div>
        </div>
      </div>
    </aside>

     <!-- Grid de Productos -->
     <div class="flex-grow">
      <% if (errorCatalogo) { %>
        <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-4 text-red-700">
          <%= errorCatalogo %>
        </div>
      <% } %>

      <% if (typeof success !== 'undefined' && success === 'editar') { %>
        <div class="mb-4 rounded-md bg-green-100 border border-green-400 text-green-700 px-4 py-3">
          Producto actualizado exitosamente.
        </div>
      <% } %>

      <% if (typeof success !== 'undefined' && success === 'deshabilitar') { %>
        <div class="mb-4 rounded-md bg-green-100 border border-green-400 text-green-700 px-4 py-3">
          Producto(s) deshabilitado(s) del catálogo exitosamente.
        </div>
      <% } %>

      <% if (!productos || productos.length === 0) { %>
        <div class="rounded-lg border border-gray-200 bg-white p-8 text-center text-gray-600">
          No hay productos disponibles por el momento.
        </div>
      <% } else { %>
        <div data-catalogo-grid data-page-size="20" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% productos.forEach((producto) => { %>
            <% const idProducto = producto.id_producto; %>
            <% const urlDetalle = idProducto != null && idProducto !== '' ? `/empleado/detalle-producto/${idProducto}` : null; %>
            <div data-producto-card 
                 data-unidad="<%= (producto.unidad_venta_producto || '').toLowerCase() %>" 
                 data-search="<%= ((producto.nombre_producto || '') + ' ' + (producto.descripcion_producto || '')).toLowerCase() %>"
                 class="flex flex-col h-full bg-white border border-gray-200 rounded-lg p-3 hover:shadow-lg transition-shadow">
              <a href="<%= urlDetalle || '#' %>" class="relative w-full aspect-square bg-gray-50 rounded-md mb-3 flex items-center justify-center p-4 block<%= urlDetalle ? '' : ' pointer-events-none opacity-70' %>" aria-disabled="<%= urlDetalle ? 'false' : 'true' %>">
                <img
                  src="<%= producto.foto_producto || 'https://placehold.co/400x400/ffffff/cccccc?text=Sin+imagen' %>"
                  alt="<%= producto.nombre_producto || 'Producto sin nombre' %>"
                  class="max-h-full max-w-full object-contain mix-blend-multiply"
                >
              </a>
              <div class="flex flex-col flex-grow">
                <a href="<%= urlDetalle || '#' %>" class="text-base text-[#007185] hover:text-[#2B6398] hover:underline line-clamp-2 leading-tight mb-1 font-medium block<%= urlDetalle ? '' : ' pointer-events-none text-gray-400' %>">
                  <%= producto.nombre_producto || producto.nombre || 'Producto sin nombre' %>
                </a>
                <% const totalResenas = Number(producto.total_resenas || 0); %>
                <% const promedioPuntuacion = Number(producto.promedio_puntuacion || 0); %>
                <% const estrellasCompletas = Math.floor(promedioPuntuacion); %>
                <% const tieneMedia = (promedioPuntuacion - estrellasCompletas) >= 0.5; %>
                <% const estrellasVacias = 5 - estrellasCompletas - (tieneMedia ? 1 : 0); %>

                <p class="text-sm text-gray-600 mb-2 line-clamp-2">
                  <%= producto.descripcion_producto || 'Sin descripcion disponible.' %>
                </p>
                <div class="flex items-center gap-1 mb-2">
                  <span class="inline-flex items-center text-amber-400 leading-none">
                    <% for (let i = 0; i < estrellasCompletas; i += 1) { %>
                      <span class="material-icons text-[16px]">star</span>
                    <% } %>
                    <% if (tieneMedia) { %>
                      <span class="material-icons text-[16px]">star_half</span>
                    <% } %>
                    <% for (let i = 0; i < estrellasVacias; i += 1) { %>
                      <span class="material-icons text-[16px] text-gray-300">star_border</span>
                    <% } %>
                  </span>
                  <span class="text-xs text-gray-600">
                    <%= totalResenas > 0 ? `${promedioPuntuacion.toFixed(1)} (${totalResenas} reseñas)` : 'Sin reseñas' %>
                  </span>
                </div>

                <div class="mt-auto">
                  <div class="flex items-end gap-2 mb-3 text-gray-900">
                    <span class="text-2xl font-semibold">
                      $<%= Number(producto.precio_producto ?? 0).toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                    </span>
                    <span class="text-xs text-gray-500">
                      <%= producto.unidad_venta_producto || '' %>
                    </span>
                  </div>
                  <% if (!urlDetalle) { %>
                    <p class="text-xs text-amber-700 mb-2">No hay id de producto en los datos del catálogo; revisa la función get_catalogo_productos_habilitados.</p>
                  <% } %>

                  <!-- Botones Editar y Eliminar -->
                  <div class="flex gap-2 w-full">
        
                    <a href="/empleado/producto/editar/<%= producto.id_producto %>"
   class="flex-1 bg-[#007185] hover:bg-[#005d6e] border border-[#005d6e] rounded-full py-1.5 flex justify-center items-center text-white transition-colors shadow-sm"
   title="Editar producto">
    <span class="material-icons text-[18px]">edit</span>
</a>
                   <button type="button"
                            data-id="<%= idProducto %>"
                            class="btn-deshabilitar flex-1 bg-red-600 hover:bg-red-700 border border-red-700 rounded-full py-1.5 flex justify-center items-center text-white transition-colors shadow-sm" 
                            title="Deshabilitar producto">
                           <span class="material-icons text-[18px]">block</span>
                    </button>
                </div>

                </div>
              </div>
            </div>
          <% }) %>
        </div>
        <div data-catalogo-paginacion class="mt-6 flex items-center justify-center gap-2"></div>
      <% } %>
    </div>
  </div>
</main>

<div id="modalDeshabilitar" tabindex="-1" aria-hidden="true"
      class="hidden fixed inset-0 z-50 items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
      <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
        <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
        <h3 class="mb-6 text-lg font-medium text-gray-800">¿Seguro que quieres deshabilitar el artículo seleccionado
          del catálogo activo?</h3>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <button id="btnCancelarDeshabilitar" type="button"
            class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Cancelar
          </button>
          <button id="btnConfirmarDeshabilitar" type="button"
            class="order-1 sm:order-2 flex-1 text-white bg-red-600 hover:bg-red-700 focus:ring-4 focus:outline-none focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Deshabilitar
          </button>
        </div>
      </div>
    </div>

  <!-- Form oculto que se envía al confirmar -->
  <form id="formDeshabilitar" action="/empleado/catalogo-productos/deshabilitar" method="POST" class="hidden">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <input type="hidden" id="inputIdProducto" name="productosSeleccionados" value="">
  </form>

  <% if (typeof errorCargarProducto !== 'undefined' && errorCargarProducto) { %>
    <div id="modalErrorCargarProducto" tabindex="-1" aria-hidden="true"
      class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
      <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
        <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
        <h3 class="mb-6 text-lg font-medium text-gray-800">El producto solicitado no existe o no pudo ser cargado.</h3>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <button id="btnModalErrorCargarProducto" type="button"
            class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Aceptar
          </button>
        </div>
      </div>
    </div>
  <% } %>

  <% if (typeof errorModificar !== 'undefined' && errorModificar) { %>
    <div id="modalErrorModificar" tabindex="-1" aria-hidden="true"
      class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
      <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
        <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
        <h3 class="mb-6 text-lg font-medium text-gray-800">Lo siento, ocurrió un error al modificar el catálogo. Por favor intenta de nuevo.</h3>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <button id="btnModalErrorModificar" type="button"
            class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Aceptar
          </button>
        </div>
      </div>
    </div>
  <% } %>

  
 <%- include('../partials/footer') %>
 <script src="/js/catalogo-preventa-countdown.js"></script>
 <script src="/js/catalogo-paginacion.js"></script>
 <script src="/js/catalogo-productos.js"></script>
 <script src="/js/filtros-catalogo.js"></script>
</body>
</html>
