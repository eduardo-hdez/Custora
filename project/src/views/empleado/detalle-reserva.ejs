<!DOCTYPE html>
<html lang="es">

<head>
  <%- include('../partials/head') %>
</head>

<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

    <main class="w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">

      <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <h1 class="text-2xl font-bold text-gray-900">Detalle de reserva</h1>
        <a href="/empleado/tabla-reservas"
          class="inline-flex items-center gap-1 text-sm font-medium text-[#2B6398] hover:text-[#1f476e]">
          <span class="material-icons text-[18px]">arrow_back</span>
          Volver al historial
        </a>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden mb-6">
        <div
          class="bg-gray-100 px-4 sm:px-6 py-4 border-b border-gray-200 flex flex-wrap justify-between items-start gap-4">
          <div class="flex flex-col">
            <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Folio</span>
            <span class="text-gray-900 font-semibold">
              <%= reserva.folio %>
            </span>
          </div>
          <div class="flex flex-col">
            <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Fecha</span>
            <span class="text-gray-900">
              <%= new Date(reserva.fechaReserva).toLocaleString('es-MX') %>
            </span>
          </div>
          <div class="flex flex-col">
            <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Estado</span>
            <span class="<%= reserva.estadoReserva ? 'text-green-700' : 'text-red-700' %> font-semibold">
              <%= reserva.estadoTexto %>
            </span>
          </div>
        </div>

        <div class="p-4 sm:p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 text-sm">
          <div>
            <p class="text-gray-500">Sucursal</p>
            <p class="text-gray-900 font-medium">
              <%= reserva.sucursal %>
            </p>
          </div>
          <div>
            <p class="text-gray-500">Enviar a:</p>
            <p class="text-gray-900 font-medium">
              <%= reserva.sucursalUbicacion %>
            </p>
          </div>
          <div>
            <p class="text-gray-500">Peso total</p>
            <p class="text-gray-900 font-medium">
              <%= reserva.pesoTotal.toFixed(2) %> kg
            </p>
          </div>
          <div>
            <p class="text-gray-500">Total</p>
            <p class="text-gray-900 font-semibold text-base">$<%= reserva.total.toFixed(2) %>
            </p>
          </div>
        </div>
      </div>



      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="px-4 sm:px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-bold text-gray-900">Productos reservados</h2>
        </div>

        <div class="p-4 sm:p-6 flex flex-col gap-5">
          <% reserva.productos.forEach((producto, idx) => { %>
            <div class="flex flex-col sm:flex-row items-start gap-4">
              <div class="w-20 h-20 sm:w-24 sm:h-24 flex-shrink-0 bg-white rounded-md border border-gray-200 p-2 flex items-center justify-center">
                <img src="<%= producto.foto %>" alt="<%= producto.nombre %>" class="max-h-full max-w-full object-contain">
              </div>
              <div class="flex-grow min-w-0">
                <p class="text-base font-medium text-[#2B6398]">
                  <%= producto.nombre %>
                </p>
                <p class="text-sm text-gray-500 mt-1">ID producto: <span class="text-gray-700 font-medium"><%= producto.id %></span></p>
                <p class="text-sm text-gray-500 mt-1">Unidad de venta: <%= producto.unidad %></p>
                <p class="text-sm text-gray-500">Cantidad: <%= producto.cantidad %></p>
                <% 
                  const totalResenas = Number(producto.totalResenas || 0);
                  const promedioPuntuacion = Number(producto.promedioPuntuacion || 0);
                  const estrellasCompletas = Math.floor(promedioPuntuacion);
                  const tieneMedia = (promedioPuntuacion - estrellasCompletas) >= 0.5;
                  const estrellasVacias = 5 - estrellasCompletas - (tieneMedia ? 1 : 0);
                %>
                <p class="text-sm text-gray-500 mt-1 flex items-center gap-1">
                  <span class="inline-flex items-center text-amber-400 leading-none">
                    <% for (let i = 0; i < estrellasCompletas; i++) { %>
                      <span class="material-icons text-[16px]">star</span>
                    <% } %>
                    <% if (tieneMedia) { %>
                      <span class="material-icons text-[16px]">star_half</span>
                    <% } %>
                    <% for (let i = 0; i < estrellasVacias; i++) { %>
                      <span class="material-icons text-[16px] text-gray-300">star_border</span>
                    <% } %>
                  </span>
                  <span class="text-gray-700">
                    <%= totalResenas > 0 ? `${promedioPuntuacion.toFixed(1)} (${totalResenas})` : 'Sin reseñas' %>
                  </span>
                </p>
                <div class="mt-3">
                  <a href="/empleado/detalle-producto/<%= producto.id %>"
                    class="inline-flex items-center gap-1.5 bg-[#2B6398] hover:bg-[#1f476e] text-white px-3 py-1.5 rounded-md text-sm font-medium transition-colors">
                    <span class="material-icons text-[18px]">visibility</span>
                    Ver artículo
                  </a>
                </div>
              </div>
            </div>
            <% if (idx < reserva.productos.length - 1) { %>
              <hr class="border-gray-100">
            <% } %>
          <% }) %>
        </div>
      </div>
    </main>

    <%- include('../partials/footer') %>
</body>

</html>