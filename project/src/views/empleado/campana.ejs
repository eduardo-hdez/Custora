<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

  <main class="w-full flex flex-col items-center pb-16 flex-grow bg-white">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Campañas</h1>
          <p class="text-sm text-gray-500 mt-1">Consulta campañas pasadas, la vigente y las programadas. Gestiona banners por campaña.</p>
        </div>
        <a href="/empleado/campanas/nueva" class="inline-flex items-center justify-center gap-2 bg-[#007185] hover:bg-[#005d6e] text-white px-4 py-2 rounded-lg font-medium shadow-sm transition-colors w-full md:w-auto">
          <span class="material-icons text-sm">add_circle_outline</span>
          Crear nueva campaña
        </a>
      </div>

      <!-- Tabla de Campañas -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Campaña</th>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-center">Estado</th>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-center">Vigencia</th>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-center">Visibilidad</th>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% if (campanas && campanas.length > 0) { %>
                <% campanas.forEach(function (c) { %>
                  <tr class="hover:bg-gray-50 transition-colors group">
                    <!-- Columna: Nombre e ID -->
                    <td class="px-6 py-4">
                      <div class="flex flex-col">
                        <span class="text-sm font-semibold text-gray-900"><%= c.nombre %></span>
                        <span class="text-xs font-mono text-gray-400 mt-0.5">ID: <%= c.id %></span>
                      </div>
                    </td>

                    <!-- Columna: Estado Temporal -->
                    <td class="px-6 py-4 text-center">
                      <% if (c.estadoCalculado === 'actual') { %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800 ring-1 ring-emerald-600/10">
                          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1.5 animate-pulse"></span>
                          En curso
                        </span>
                      <% } else if (c.estadoCalculado === 'programada') { %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-sky-100 text-sky-800 ring-1 ring-sky-600/10">
                          Programada
                        </span>
                      <% } else { %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 ring-1 ring-gray-600/10">
                          Pasada
                        </span>
                      <% } %>
                    </td>

                    <!-- Columna: Fechas -->
                    <td class="px-6 py-4 text-center">
                      <div class="flex flex-col items-center">
                        <span class="text-sm text-gray-600 font-medium"><%= c.fechaInicio %></span>
                        <span class="text-[10px] text-gray-400 uppercase tracking-tighter">al</span>
                        <span class="text-sm text-gray-600 font-medium"><%= c.fechaFin %></span>
                      </div>
                    </td>

                    <!-- Columna: Visibilidad (Activa/Pausada) -->
                    <td class="px-6 py-4 text-center">
                      <div class="flex justify-center">
                        <% if (c.estado) { %>
                          <span class="flex items-center text-xs text-green-600 font-medium">
                            <span class="material-icons text-[14px] mr-1">check_circle</span>
                            Activa
                          </span>
                        <% } else { %>
                          <span class="flex items-center text-xs text-red-500 font-medium">
                            <span class="material-icons text-[14px] mr-1">pause_circle</span>
                            Pausada
                          </span>
                        <% } %>
                      </div>
                    </td>

                    <!-- Columna: Acciones -->
                    <td class="px-6 py-4 text-right">
                      <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                        <!-- Editar -->
                        <a href="/empleado/campanas/<%= encodeURIComponent(c.id) %>/editar" 
                           class="p-2 text-gray-400 hover:text-[#007185] hover:bg-teal-50 rounded-lg transition-all"
                           title="Editar campaña">
                          <span class="material-icons text-[20px]">edit</span>
                        </a>

                        <!-- Banners -->
                        <a href="/empleado/campanas/<%= encodeURIComponent(c.id) %>/banners" 
                           class="p-2 text-gray-400 hover:text-[#007185] hover:bg-teal-50 rounded-lg transition-all"
                           title="Gestionar banners">
                          <span class="material-icons text-[20px]">image</span>
                        </a>

                        <!-- Toggle Estado -->
                        <form action="/empleado/campanas/<%= encodeURIComponent(c.id) %>/estado" method="POST" class="inline">
                          <input type="hidden" name="estado" value="<%= c.estado ? 'false' : 'true' %>">
                          <button type="submit" 
                                  class="p-2 rounded-lg transition-all <%= c.estado ? 'text-gray-400 hover:text-red-600 hover:bg-red-50' : 'text-gray-400 hover:text-green-600 hover:bg-green-50' %>"
                                  title="<%= c.estado ? 'Desactivar campaña' : 'Activar campaña' %>">
                            <span class="material-icons text-[20px]"><%= c.estado ? 'block' : 'play_arrow' %></span>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="px-6 py-12 text-center text-gray-500 italic">
                    No se han encontrado campañas registradas.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
