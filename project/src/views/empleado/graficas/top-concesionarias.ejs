<section class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-8">

    <header class="flex items-center gap-3 px-6 sm:px-8 py-5 bg-gray-50 border-b border-gray-200">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-[#007185]/10 text-[#007185]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <path d="M21 8v13H3V8"></path>
                <path d="M1 3h22v5H1z"></path>
                <path d="M10 12h4"></path>
            </svg>
        </span>
        <h2 class="text-xl font-extrabold text-gray-900">Top 5 Concesionarias con más reservas</h2>
    </header>

    <div class="px-6 sm:px-8 py-6">

        <div class="mb-6">

            <% if (!concesionarias || concesionarias.length===0) { %>
                <p class="text-sm text-gray-500 italic">Sin datos.</p>
                <% } else { %>
                    <ul class="divide-y divide-gray-100">
                        <% concesionarias.forEach(c=> { %>
                            <li class="flex items-baseline justify-between py-2.5">
                                <span class="text-gray-900 font-medium">
                                    <%= c.nombre_concesionaria %>
                                </span>
                                <span class="text-gray-500 text-sm whitespace-nowrap">
                                    <%= c.reservas_concesionaria.toLocaleString('es-MX') %> reservas
                                </span>
                            </li>
                            <% }) %>
                    </ul>
                    <% } %>
        </div>
    </div>
</section>