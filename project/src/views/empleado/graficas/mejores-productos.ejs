<section class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden mb-8">
  <header class="flex items-center gap-3 px-6 sm:px-8 py-5 bg-gray-50 border-b border-gray-200">
    <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-yellow-100 text-yellow-600">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
        <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
      </svg>
    </span>
    <h2 class="text-xl font-extrabold text-gray-900">Top 5 Productos Mejor Calificados</h2>
  </header>

  <div class="px-6 sm:px-8 py-6">
    <div class="flex items-center gap-2 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
        stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-yellow-600">
        <path d="M3 3v18h18"></path>
        <path d="M7 14l4-4 3 3 4-6"></path>
      </svg>
      <h3 class="text-sm font-bold tracking-wider text-yellow-600 uppercase">Ranking de Calificaciones</h3>
    </div>

    <% if (!mejoresProductos || mejoresProductos.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-10 text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-2 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
        </svg>
        <p class="text-sm italic">Aún no hay productos calificados.</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="text-gray-400 text-xs uppercase tracking-wider border-b border-gray-100">
              <th class="py-3 font-semibold">Producto</th>
              <th class="py-3 font-semibold text-center">Calificación</th>
              <th class="py-3 font-semibold text-right">Reseñas</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% mejoresProductos.forEach((prod, i) => { %>
              <tr class="group hover:bg-gray-50 transition-colors">
                <td class="py-4 flex items-center gap-4">
                  <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold shrink-0
                    <%= i === 0 ? 'bg-yellow-100 text-yellow-700' : '' %>
                    <%= i === 1 ? 'bg-gray-200 text-gray-700' : '' %>
                    <%= i === 2 ? 'bg-orange-100 text-orange-700' : '' %>
                    <%= i > 2 ? 'bg-white text-gray-400 border border-gray-200' : '' %>">
                    <%= i + 1 %>
                  </span>
                  <div class="w-10 h-10 rounded-md bg-gray-100 overflow-hidden flex-shrink-0 border border-gray-100">
                    <% if (prod.foto) { %>
                      <img src="<%= prod.foto %>" alt="<%= prod.nombre %>" class="w-full h-full object-cover">
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center text-gray-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      </div>
                    <% } %>
                  </div>
                  <span class="text-sm font-medium text-gray-900 truncate max-w-[200px] sm:max-w-xs"><%= prod.nombre %></span>
                </td>
                <td class="py-4">
                  <div class="flex items-center justify-center gap-1">
                    <span class="text-sm font-bold text-gray-900"><%= prod.promedio.toFixed(1) %></span>
                    <div class="flex text-yellow-400">
                      <% for (let star = 1; star <= 5; star++) { %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 <%= star <= Math.round(prod.promedio) ? 'fill-current' : 'text-gray-200' %>" viewBox="0 0 20 20" fill="currentColor">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      <% } %>
                    </div>
                  </div>
                </td>
                <td class="py-4 text-right">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-800">
                    <%= prod.conteo %> reseñas
                  </span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</section>
