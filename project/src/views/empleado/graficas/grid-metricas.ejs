<div class="bg-white p-5 rounded-lg border border-gray-200 shadow-sm mb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <!-- Card 1 -->
        <div class="card-ingreso bg-gradient-to-br from-blue-50 to-cyan-50 border border-blue-100 p-5 rounded-lg">
            <div class="flex items-center justify-between">
                <div>
                    <% if (!ingresosHoy) { %>
                        <p class="text-red-500 text-sm">Error al cargar ingresos del día.</p>
                        <% } else { %>
                            <p class="text-sm font-semibold text-blue-800 uppercase">Ingresos de Hoy</p>
                            <p class="text-3xl font-bold text-gray-900 mt-2">
                                $<%= Number(ingresosHoy).toLocaleString('es-MX') %>
                            </p>
                            <p class="text-sm text-gray-500 mt-1">En reservas confirmadas</p>
                            <% } %>
                </div>
                <div class="bg-blue-100 p-3 rounded-full">
                    <!-- Icono -->
                    <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                        </path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Card 2 -->
        <div class="card-ingreso bg-gradient-to-br from-blue-50 to-cyan-50 border border-blue-100 p-5 rounded-lg">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-semibold text-blue-800 uppercase">Promedio de ingresos diarios</p>
                    <p class="text-3xl font-bold text-gray-900 mt-2">ingreso promedio</p>
                    <p class="text-sm text-gray-500 mt-1">Última semana</p>
                </div>
                <div class="bg-blue-100 p-3 rounded-full">
                    <!-- Icono -->
                    <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                        </path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Card 3 -->
        <div class="card-ingreso bg-gradient-to-br from-blue-50 to-cyan-50 border border-blue-100 p-5 rounded-lg">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-semibold text-blue-800 uppercase">Concesionaria Top</p>
                    <p class="text-3xl font-bold text-gray-900 mt-2">comex %></p>
                    <p class="text-sm text-gray-500 mt-1">total de reservas</p>
                </div>
                <div class="bg-blue-100 p-3 rounded-full">
                    <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M8 21h8m-4-4v4m0-4a7 7 0 007-7V5H5v5a7 7 0 007 7zM16 5V3H8v2">
                        </path>
                    </svg>
                </div>
            </div>
        </div>

    </div>
</div>