<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

  <main class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">
    <div class="mb-6">
      <a href="/empleado/campanas" class="inline-flex items-center gap-1 text-sm text-[#007185] hover:text-[#005d6e] hover:underline">
        <span class="material-icons text-[18px]">arrow_back</span>
        Volver a campañas
      </a>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-8 max-w-2xl">
      <!-- 1. Título actualizado -->
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Editar campaña</h1>
      <p class="text-sm text-gray-500 mb-6">Modifica los campos que necesites</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800" role="alert">
          <%= error %>
        </div>
      <% } %>

      <%
        const urlBanner = String(campana.banners || '').trim() || null;
      %>
      <!-- 2. Action apunta a la ruta de editar -->
      <form method="post" enctype="multipart/form-data"
        action="/empleado/campanas/<%= encodeURIComponent(campana.id) %>/editar?_csrf=<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" class="space-y-5">

        <div>
          <label for="idCampana" class="block text-sm font-medium text-gray-700 mb-1">ID campaña</label>
          <!-- 3. ID deshabilitado, no se puede cambiar -->
          <input type="text" id="idCampana" name="idCampana"
            value="<%= campana.idCampana %>"
            disabled
            class="w-full rounded-lg border border-gray-200 bg-gray-100 px-3 py-2 text-gray-500 shadow-sm cursor-not-allowed" />
        </div>
        <div>
          <label for="nombreCampana" class="block text-sm font-medium text-gray-700 mb-1">Nombre de la campaña</label>
          <input type="text" id="nombreCampana" name="nombreCampana" required
            value="<%= campana.nombreCampana %>"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-[#007185] focus:ring-1 focus:ring-[#007185]" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="fechaInicio" class="block text-sm font-medium text-gray-700 mb-1">Fecha de inicio</label>
            <input type="date" id="fechaInicio" name="fechaInicio" required
              value="<%= campana.fechaInicio %>"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-[#007185] focus:ring-1 focus:ring-[#007185]" />
          </div>
          <div>
            <label for="fechaFin" class="block text-sm font-medium text-gray-700 mb-1">Fecha final</label>
            <input type="date" id="fechaFin" name="fechaFin" required
              value="<%= campana.fechaFin %>"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-[#007185] focus:ring-1 focus:ring-[#007185]" />
          </div>
        </div>
        <div class="space-y-2">
          <span class="block text-sm font-medium text-gray-700">Banner actual</span>
          <% if (urlBanner) { %>
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-2 max-w-md">
              <img src="<%= urlBanner %>" alt="Banner actual" class="max-h-32 w-auto object-contain mx-auto" onerror="this.style.display='none'" />
            </div>
          <% } else { %>
            <p class="text-sm text-gray-500">Sin banner. Puedes subir uno abajo.</p>
          <% } %>
        </div>

        <div class="border-t border-gray-200 pt-5 space-y-3">
          <h2 class="text-sm font-semibold text-gray-800">Cambiar banner</h2>
          <div>
            <label for="bannerImagen" class="block text-sm font-medium text-gray-700 mb-1">Imagen</label>
            <input type="file" id="bannerImagen" name="bannerImagen" accept="image/jpeg,image/png,image/webp,image/gif"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-[#007185] focus:ring-1 focus:ring-[#007185] file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-sm file:bg-gray-100 file:text-gray-700 hover:file:bg-gray-200" />
            <p class="mt-1 text-xs text-gray-500">JPEG, JPG, PNG. Máx. 5 MB.</p>
          </div>
        </div>
        <div>
          <label for="tiempoCancelacion" class="block text-sm font-medium text-gray-700 mb-1">Tiempo de cancelación (minutos)</label>
          <input type="number" id="tiempoCancelacion" name="tiempoCancelacion" min="0" step="1"
            value="<%= campana.tiempoCancelacion %>"
            class="w-full max-w-xs rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-[#007185] focus:ring-1 focus:ring-[#007185]"
            placeholder="ej. 15" />
          <p class="mt-1 text-xs text-gray-500">Ventana en minutos antes del cierre para permitir cancelaciones.</p>
        </div>
        <div class="flex flex-wrap gap-3 pt-2">
          <button type="submit" class="inline-flex items-center justify-center gap-2 bg-[#007185] hover:bg-[#005d6e] text-white px-5 py-2.5 rounded-lg font-medium shadow-sm transition-colors">
            <span class="material-icons text-sm">save</span>
            Guardar cambios
          </button>
          <a href="/empleado/campanas" class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 font-medium transition-colors">
            Cancelar
          </a>
        </div>
      </form>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>