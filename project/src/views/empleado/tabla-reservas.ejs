<!DOCTYPE html>
<html lang="es">

<head>
  <%- include('../partials/head') %>
</head>

<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

    <main class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">

      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
        <h1 class="text-2xl font-bold text-gray-900">Tabla de Reservas</h1>
      </div>

      <!-- Filtros de Búsqueda -->
      <div class="bg-white p-5 rounded-lg border border-gray-200 shadow-sm mb-8">
        <h2 class="text-base font-semibold text-gray-800 mb-4 border-b pb-2">Filtros de Búsqueda</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 items-end">
          <div class="w-full">
            <label for="concesionaria-filter" class="block text-sm font-medium text-gray-700 mb-1">Concesionaria</label>
            <select id="concesionaria-filter"
              class="w-full border border-gray-300 rounded-md py-2 pl-3 pr-8 text-sm focus:ring-[#007185] focus:border-[#007185] bg-white outline-none shadow-sm cursor-pointer">
              <option value="todas">Todas las concesionarias</option>
              <option value="auto-grupo">Auto Grupo S.A. de C.V.</option>
              <option value="motors-sur">Motors del Sur</option>
              <option value="excelencia-automotriz">Excelencia Automotriz</option>
            </select>
          </div>
          <div class="w-full">
            <label for="cuenta-filter" class="block text-sm font-medium text-gray-700 mb-1">Cuenta</label>
            <select id="cuenta-filter"
              class="w-full border border-gray-300 rounded-md py-2 pl-3 pr-8 text-sm focus:ring-[#007185] focus:border-[#007185] bg-white outline-none shadow-sm cursor-pointer">
              <option value="todas">Todas las cuentas</option>
              <option value="principal">Principal</option>
              <option value="mantenimiento">Mantenimiento y Reparación</option>
              <option value="pintura">Taller de Pintura</option>
            </select>
          </div>
          <div class="w-full">
            <label for="sucursal-filter" class="block text-sm font-medium text-gray-700 mb-1">Sucursal</label>
            <select id="sucursal-filter"
              class="w-full border border-gray-300 rounded-md py-2 pl-3 pr-8 text-sm focus:ring-[#007185] focus:border-[#007185] bg-white outline-none shadow-sm cursor-pointer">
              <option value="todas">Todas las sucursales</option>
              <option value="centro">Centro</option>
              <option value="norte">Norte (Industrial)</option>
              <option value="sur">Sur</option>
              <option value="este">Este</option>
            </select>
          </div>
          <div class="w-full">
            <button
              class="w-full bg-[#007185] hover:bg-[#005d6e] text-white px-6 py-2 rounded-md text-sm font-medium transition-colors shadow-sm flex items-center justify-center gap-2">
              <span class="material-icons text-[18px]">filter_list</span> Filtrar Resultados
            </button>
          </div>
        </div>
      </div>

      <!-- Lista de Reservas -->
      <div class="flex flex-col gap-6">
        <% if (!reservas || reservas.length===0) { %>
          <tr>
            <td colspan="6" class="p-4 text-center text-gray-600">
              La campaña actual (seleccionada) no cuenta con reservas registradas por el
              momento.
            </td>
          </tr>
          <% } else { %>
            <% reservas.forEach((reserva)=> { %>
              <!-- Reserva 1 (Más Reciente) -->
              <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden flex flex-col">
                <div
                  class="bg-gray-100 px-4 sm:px-6 py-4 border-b border-gray-200 flex flex-wrap md:flex-nowrap justify-between items-start gap-4">
                  <div class="flex flex-wrap gap-6 sm:gap-10 text-sm text-gray-600">
                    <div class="flex flex-col">
                      <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Fecha de
                        Reserva</span>
                      <span class="text-gray-900">
                        <%= reserva.fecha_reserva %>
                      </span>
                    </div>
                    <div class="flex flex-col">
                      <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Total</span>
                      <span class="text-gray-900 font-medium">
                        $<%= reserva.productos.reduce((total, p) => total + (p.precio_producto * p.unidades_reservadas), 0).toLocaleString('en-US', {minimumFractionDigits: 2}) %>
                      </span>
                    </div>
                    <div class="flex flex-col">
                      <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Concesionaria /
                        Cuenta</span>
                      <span class="text-[#007185] font-medium hover:underline cursor-pointer">
                        <%= reserva.nombre_concesionaria %>
                      </span>
                    </div>
                    <div class="flex flex-col">
                      <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Sucursal</span>
                      <span class="text-gray-900 font-medium">
                        <%= reserva.nombre_sucursal %>
                      </span>
                    </div>
                  </div>
                  <div class="flex flex-col items-start md:items-end text-sm w-full md:w-auto">
                    <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Folio</span>
                    <span class="text-gray-900 font-medium">
                      <%= reserva.folio %>
                    </span>
                    <div class="flex items-center gap-2 mt-1">
                      <a href="/empleado/detalle-reserva"
                        class="text-[#007185] hover:text-[#005d6e] hover:underline">Ver detalles</a>
                    </div>
                  </div>
                </div>
                <% if (reserva.estado_reserva) { %>
                  <div class="p-4 sm:p-6">
                    <div
                      class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-6 gap-4 border-b border-gray-100 pb-6">
                      <div>
                        <h3 class="text-lg font-bold text-gray-900 flex items-center gap-2">
                          <span class="material-icons text-green-600">check_circle</span>
                          Confirmada
                        </h3>
                      </div>
                    </div>
                    <% } else { %>
                      <div class="p-4 sm:p-6">
                        <div
                          class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-6 gap-4 border-b border-gray-100 pb-6">
                          <div>
                            <h3 class="text-lg font-bold text-red-700 flex items-center gap-2">
                              <span class="material-icons text-red-600">cancel</span>
                              Cancelada
                            </h3>
                          </div>
                        </div>
                        <% } %>

                          <div class="flex flex-col gap-6">
                            <% reserva.productos.forEach((producto, index) => { %>
                              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                                <div
                                  class="w-20 h-20 sm:w-24 sm:h-24 flex-shrink-0 bg-white rounded-md border border-gray-200 p-2 flex items-center justify-center">
                                  <img src="<%= producto.foto_producto %>"
                                    alt="<%= producto.nombre_producto %>"
                                    class="max-h-full max-w-full object-contain mix-blend-multiply">
                                </div>
                                <div class="flex flex-col flex-grow">
                                  <a href="#"
                                    class="text-base font-medium text-[#007185] hover:text-[#005d6e] hover:underline"><%= producto.nombre_producto %></a>
                                  <span class="text-sm text-gray-500 mt-1">Unidad: <%= producto.unidad_venta_producto %> • Cantidad: <%= producto.unidades_reservadas %></span>
                                </div>
                                <div class="flex items-center text-gray-900 font-medium whitespace-nowrap">
                                  $<%= (producto.precio_producto).toLocaleString('en-US', {minimumFractionDigits: 2}) %>
                                </div>
                              </div>
                              <% if (index < reserva.productos.length - 1) { %>
                                <hr class="border-gray-100">
                              <% } %>
                            <% }); %>
                          </div>
                      </div>
                  </div>
                <% }); %>
            <% } %>
      </div>
    </main>

    <%- include('../partials/footer') %>
</body>

</html>