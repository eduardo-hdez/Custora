<!DOCTYPE html>
<html lang="es">

<head>
  <%- include('../partials/head') %>
</head>

<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

    <main class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">

      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
        <h1 class="text-2xl font-bold text-gray-900">Tabla de Reservas</h1>
      </div>

      <!-- Filtros de Búsqueda -->
      <div class="bg-white p-5 rounded-lg border border-gray-200 shadow-sm mb-8">
        <h2 class="text-base font-semibold text-gray-800 mb-4 border-b pb-2">Filtros de Búsqueda</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-4 items-end">
          <div class="lg:col-span-4 relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <span class="material-icons text-gray-400 text-sm">search</span>
            </div>
            <input type="text" id="busquedaGeneral"
              placeholder="Buscar por folio, concesionaria, sucursal o producto..."
              class="w-full pl-10 pr-3 border border-gray-300 rounded-lg py-2 text-sm focus:ring-[#007185] focus:border-[#007185]">
          </div>
          <div class="lg:col-span-2">
            <label for="filtroEstado" class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
            <select id="filtroEstado"
              class="w-full border border-gray-300 rounded-md py-2 pl-3 pr-8 text-sm focus:ring-[#007185] focus:border-[#007185] bg-white outline-none shadow-sm cursor-pointer">
              <option value="todas">Todos los estados</option>
              <option value="confirmada">Confirmadas</option>
              <option value="cancelada">Canceladas</option>
            </select>
          </div>
          <div class="lg:col-span-2">
            <label for="filtroFechaInicio" class="block text-sm font-medium text-gray-700 mb-1">Fecha inicio</label>
            <input type="date" id="filtroFechaInicio"
              class="w-full border border-gray-300 rounded-md py-2 pl-3 pr-3 text-sm focus:ring-[#007185] focus:border-[#007185] bg-white outline-none shadow-sm cursor-pointer text-gray-700">
          </div>
          <div class="lg:col-span-2">
            <label for="filtroFechaFin" class="block text-sm font-medium text-gray-700 mb-1">Fecha fin</label>
            <input type="date" id="filtroFechaFin"
              class="w-full border border-gray-300 rounded-md py-2 pl-3 pr-3 text-sm focus:ring-[#007185] focus:border-[#007185] bg-white outline-none shadow-sm cursor-pointer text-gray-700">
          </div>
          <div class="lg:col-span-2">
            <button id="botonFiltrar"
              class="w-full bg-[#007185] hover:bg-[#005d6e] text-white px-4 py-2 rounded-md text-sm font-medium transition-colors shadow-sm flex items-center justify-center gap-2 max-h-[38px] truncate">
              <span class="material-icons text-[18px]">filter_list</span> Filtrar
            </button>
          </div>
        </div>
      </div>
      <% if (errorRecuperacion) { %>
        <div id="modalErrorRecuperacion" tabindex="-1" aria-hidden="true"
          class="<%= errorRecuperacion ? '' : 'hidden' %> fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
          <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
            <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
            <h3 class="mb-6 text-lg font-medium text-gray-800">Lo siento, ocurrió un error al recuperar las reservas
              del catálogo actual de la
              base de datos. Por favor intenta más tarde.</h3>
            <div class="flex flex-col sm:flex-row justify-center gap-3">
              <a href="/empleado">
                <button id="btnModalErrorRecuperacion" type="button"
                  class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
                  Aceptar
                </button>
              </a>
            </div>
          </div>
        </div>
        <% } %>
          <!-- Lista de Reservas -->
          <div class="flex flex-col gap-6">
            <% if (!reservas || reservas.length===0) { %>
              <tr>
                <td colspan="6" class="p-4 text-center text-gray-600">
                  La campaña actual (seleccionada) no cuenta con reservas registradas por el
                  momento.
                </td>
              </tr>
              <% } else { %>
                <% reservas.forEach((reserva)=> { %>

                  <div
                    class="card-reserva bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden flex flex-col"
                    data-folio="<%= reserva.folio %>" data-concesionaria="<%= reserva.nombre_concesionaria %>"
                    data-sucursal="<%= reserva.nombre_sucursal %>"
                    data-estado="<%= reserva.estado_reserva ? 'confirmada' : 'cancelada' %>"
                    data-fecha-reserva="<%= reserva.fecha_reserva %>"
                    data-productos="<%= reserva.productos.map(p => p.nombre_producto).join(', ') %>">
                    <!-- Encabezado de reserva desplegable -->
                    <div
                      class="encabezado-reserva bg-gray-100 px-4 sm:px-6 py-4 border-b border-gray-200 flex flex-wrap md:flex-nowrap justify-between items-start gap-4 cursor-pointer select-none hover:bg-gray-200 transition-colors">
                      <div class="flex flex-wrap gap-6 sm:gap-10 text-sm text-gray-600">
                        <div class="flex flex-col">
                          <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Fecha de
                            Reserva</span>
                          <span class="text-gray-900">
                            <%= reserva.fecha_reserva %>
                          </span>
                        </div>
                        <div class="flex flex-col">
                          <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Total</span>
                          <span class="text-gray-900 font-medium">
                            $<%= (reserva.precio_reserva).toLocaleString('en-US', {minimumFractionDigits: 2}) %>
                          </span>
                        </div>
                        <div class="flex flex-col">
                          <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Concesionaria
                            /
                            Cuenta</span>
                          <span class="text-[#007185] font-medium">
                            <%= reserva.nombre_concesionaria %>
                          </span>
                        </div>
                        <div class="flex flex-col">
                          <span
                            class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Sucursal</span>
                          <span class="text-gray-900 font-medium">
                            <%= reserva.nombre_sucursal %>
                          </span>
                        </div>
                      </div>
                      <div class="flex items-center gap-4 text-sm w-full md:w-auto">
                        <div class="flex flex-col items-start md:items-end">
                          <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Folio</span>
                          <span class="text-gray-900 font-medium">
                            <%= reserva.folio %>
                          </span>
                        </div>
                        <span
                          class="material-icons text-gray-500 flecha-despliegue transition-transform duration-300 text-2xl">expand_more</span>
                      </div>
                    </div>

                    <div class="contenido-reserva hidden">
                      <% if (reserva.estado_reserva) { %>
                        <div class="p-4 sm:p-6">
                          <div
                            class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-6 gap-4 border-b border-gray-100 pb-6">
                            <div>
                              <h3 class="text-lg font-bold text-gray-900 flex items-center gap-2">
                                <span class="material-icons text-green-600">check_circle</span>
                                Confirmada
                              </h3>
                            </div>
                            <div class="flex items-center gap-2">
                              <a href="/empleado/detalle-reserva/<%= reserva.folio %>"
                                class="text-[#007185] hover:text-[#005d6e] hover:underline text-sm font-medium">Ver
                                detalles</a>
                            </div>
                          </div>
                          <% } else { %>
                            <div class="p-4 sm:p-6">
                              <div
                                class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-6 gap-4 border-b border-gray-100 pb-6">
                                <div>
                                  <h3 class="text-lg font-bold text-red-700 flex items-center gap-2">
                                    <span class="material-icons text-red-600">cancel</span>
                                    Cancelada
                                  </h3>
                                </div>
                                <div class="flex items-center gap-2">
                                  <a href="/empleado/detalle-reserva/<%= reserva.folio %>"
                                    class="text-[#007185] hover:text-[#005d6e] hover:underline text-sm font-medium">Ver
                                    detalles</a>
                                </div>
                              </div>
                              <% } %>

                                <div class="flex flex-col gap-6">
                                  <% reserva.productos.forEach((producto, index)=> { %>
                                    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                                      <div
                                        class="w-20 h-20 sm:w-24 sm:h-24 flex-shrink-0 bg-white rounded-md border border-gray-200 p-2 flex items-center justify-center">
                                        <img src="<%= producto.foto_producto %>" alt="<%= producto.nombre_producto %>"
                                          class="max-h-full max-w-full object-contain mix-blend-multiply">
                                      </div>
                                      <div class="flex flex-col flex-grow">
                                        <a href="#"
                                          class="text-base font-medium text-[#007185] hover:text-[#005d6e] hover:underline">
                                          <%= producto.nombre_producto %>
                                        </a>
                                        <span class="text-sm text-gray-500 mt-1">Unidad: <%=
                                            producto.unidad_venta_producto %>
                                            • Cantidad: <%= producto.unidades_reservadas %></span>
                                      </div>
                                      <div class="flex items-center text-gray-900 font-medium whitespace-nowrap">
                                        $<%= (producto.precio_producto).toLocaleString('en-US', {minimumFractionDigits:
                                          2}) %>
                                      </div>
                                    </div>
                                    <% if (index < reserva.productos.length - 1) { %>
                                      <hr class="border-gray-100">
                                      <% } %>
                                        <% }); %>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                      <% } %>
                  </div>
    </main>

    <%- include('../partials/footer') %>
      <script src="/js/tabla-reservas.js"></script>
</body>

</html>