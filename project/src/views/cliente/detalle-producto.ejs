<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-cliente') %>

  <main class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">
    <% if (errorDetalle) { %>
      <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4 text-red-800">
        <%= errorDetalle %>
      </div>
      <p class="text-center">
        <a href="/cliente/catalogo" class="text-[#007185] hover:text-[#2B6398] font-medium underline">Volver al catálogo</a>
      </p>
    <% } else if (producto) { %>
      <% if (mensajeCalificacion) { %>
        <div class="mb-6 rounded-lg border border-green-200 bg-green-50 p-4 text-green-800">
          <%= mensajeCalificacion %>
        </div>
      <% } %>
      <% if (errorCalificacion) { %>
        <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4 text-red-800">
          <%= errorCalificacion %>
        </div>
      <% } %>
      <% const nombre = producto.nombre_producto || 'Producto'; %>
      <% const descripcion = producto.descripcion_producto || ''; %>
      <% const precio = Number(producto.precio_producto ?? 0); %>
      <% const unidad = producto.unidad_venta_producto || ''; %>
      <% const foto = producto.foto_producto || 'https://placehold.co/600x600/ffffff/cccccc?text=Sin+imagen'; %>
      <% const promedioResenas = Number(resumenResenas?.promedio || 0); %>
      <% const totalResenas = Number(resumenResenas?.total || 0); %>
      <% const estrellasCompletas = Math.floor(promedioResenas); %>
      <% const tieneMedia = (promedioResenas - estrellasCompletas) >= 0.5; %>
      <% const estrellasVacias = 5 - estrellasCompletas - (tieneMedia ? 1 : 0); %>

      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-6 lg:p-10 items-start">
          <div class="flex justify-center items-center bg-gray-50 rounded-lg p-6 border border-gray-100 h-full max-h-[450px]">
            <img src="<%= foto %>" alt="<%= nombre %>" class="max-w-full max-h-[320px] object-contain mix-blend-multiply rounded-md">
          </div>

          <div class="flex flex-col">
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4 leading-tight"><%= nombre %></h1>

            <div class="border-t border-gray-200 py-4 mb-6">
              <div class="flex items-end gap-2 text-gray-900">
                <span class="text-sm font-medium">$</span>
                <span class="text-4xl font-semibold leading-none"><%= precio.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
              </div>
              <p class="text-sm text-gray-500 mt-2">ID de producto: <span class="font-medium text-gray-700"><%= producto.id_producto %></span></p>
              <% if (unidad) { %>
                <p class="text-sm text-gray-500 mt-1">Unidad de venta: <span class="text-gray-700"><%= unidad %></span></p>
              <% } %>
              <p class="text-sm text-gray-500 mt-1">*Precio sin IVA</p>
              <div class="mt-2 flex items-center gap-2">
                <span class="inline-flex items-center text-amber-400 leading-none">
                  <% for (let i = 0; i < estrellasCompletas; i += 1) { %>
                    <span class="material-icons text-[18px]">star</span>
                  <% } %>
                  <% if (tieneMedia) { %>
                    <span class="material-icons text-[18px]">star_half</span>
                  <% } %>
                  <% for (let i = 0; i < estrellasVacias; i += 1) { %>
                    <span class="material-icons text-[18px] text-gray-300">star_border</span>
                  <% } %>
                </span>
                <span class="text-sm text-gray-600">
                  <%= totalResenas > 0 ? `${promedioResenas.toFixed(1)} (${totalResenas} reseñas)` : 'Sin reseñas' %>
                </span>
              </div>
            </div>

            <div class="flex flex-col gap-3">
                <form method="POST" action="/cliente/carrito/agregar">
                  <input type="hidden" name="id_producto" value="<%= producto.id_producto %>">
                  <input type="hidden" name="cantidad" value="1">
                  
                  <div class="flex flex-col sm:flex-row gap-4 mb-4">
                    <div class="flex flex-col gap-2">
                      <span class="text-sm font-medium text-gray-700">Cantidad</span>
                      <div class="flex items-center border border-gray-300 rounded-md qty-container w-max">
                        <button type="button" class="px-4 py-2 hover:bg-gray-100 btn-cantidad-menos text-gray-600 font-bold">-</button>
                        <input type="text" inputmode="numeric" pattern="[0-9]*" value="1" class="w-16 text-center border-none focus:ring-0 text-base input-cantidad bg-transparent" readonly>
                        <button type="button" class="px-4 py-2 hover:bg-gray-100 btn-cantidad-mas text-gray-600 font-bold">+</button>
                      </div>
                    </div>
                  </div>

                  <button type="submit" class="w-full bg-[#2B6398] hover:bg-[#1e466b] text-white border border-[#1e466b] rounded-full py-3 px-6 font-medium flex justify-center items-center gap-2 text-lg transition-colors">
                    <span class="material-icons">shopping_cart</span>
                    Agregar al carrito
                  </button>
                </form>

                <% if (puedeCalificar) { %>
                  <a
                    href="/cliente/productos/<%= producto.id_producto %>/calificacion"
                    class="w-full bg-white hover:bg-gray-50 text-[#2B6398] border border-[#2B6398] rounded-full py-3 px-6 font-medium flex justify-center items-center gap-2 text-lg transition-colors"
                  >
                    <span class="material-icons">rate_review</span>
                    Agregar reseña
                  </a>
                <% } else { %>
                  <div class="w-full bg-gray-100 text-gray-600 border border-gray-300 rounded-full py-3 px-6 font-medium flex justify-center items-center gap-2 text-lg cursor-not-allowed">
                    <span class="material-icons">rate_review</span>
                    Ya calificaste este producto
                  </div>
                <% } %>
            </div>
          </div>
        </div>
      </div>

      <% if (descripcion) { %>
        <div class="mt-8 bg-white rounded-lg shadow-sm border border-gray-200 p-6 lg:p-10">
          <h2 class="text-xl font-bold text-gray-900 mb-4 pb-2 border-b border-gray-200">Descripción del producto</h2>
          <div class="prose max-w-none text-gray-700">
            <p class="whitespace-pre-wrap"><%= descripcion %></p>
          </div>
        </div>
      <% } %>

      <div id="resenas-producto" class="mt-8 bg-white rounded-lg shadow-sm border border-gray-200 p-6 lg:p-10">
        <h2 class="text-xl font-bold text-gray-900 mb-4 pb-2 border-b border-gray-200">Reseñas del producto</h2>
        <% const totalResenasListado = Number(resumenResenas?.total || 0); %>
        <% const promedioResenasListado = Number(resumenResenas?.promedio || 0); %>
        <% const estrellasCompletasListado = Math.floor(promedioResenasListado); %>
        <% const tieneMediaListado = (promedioResenasListado - estrellasCompletasListado) >= 0.5; %>
        <% const estrellasVaciasListado = 5 - estrellasCompletasListado - (tieneMediaListado ? 1 : 0); %>
        <div class="mb-5 flex items-center gap-2">
          <span class="inline-flex items-center text-amber-400 leading-none">
            <% for (let i = 0; i < estrellasCompletasListado; i += 1) { %>
              <span class="material-icons text-[18px]">star</span>
            <% } %>
            <% if (tieneMediaListado) { %>
              <span class="material-icons text-[18px]">star_half</span>
            <% } %>
            <% for (let i = 0; i < estrellasVaciasListado; i += 1) { %>
              <span class="material-icons text-[18px] text-gray-300">star_border</span>
            <% } %>
          </span>
          <span class="text-sm text-gray-700">
            <%= totalResenasListado > 0 ? `${promedioResenasListado.toFixed(1)} de 5 (${totalResenasListado} reseñas)` : 'Aún no hay reseñas' %>
          </span>
        </div>

        <% if (errorResenas) { %>
          <p class="text-sm text-red-700"><%= errorResenas %></p>
        <% } else if (!resenasProducto || resenasProducto.length === 0) { %>
          <p class="text-sm text-gray-600">Sé el primero en compartir tu experiencia de este producto.</p>
        <% } else { %>
          <div class="space-y-4">
            <% resenasProducto.forEach((resena, idx) => { %>
              <article class="rounded-md border border-gray-200 p-4">
                <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
                  <p class="text-sm font-medium text-gray-800"><%= resena.concesionaria %></p>
                  <p class="text-xs text-gray-500"><%= resena.fecha ? new Date(resena.fecha).toLocaleDateString('es-MX') : '' %></p>
                </div>
                <p class="text-amber-400 text-sm mb-2">
                  <% for (let i = 1; i <= 5; i += 1) { %>
                    <%= i <= Math.round(Number(resena.puntuacion || 0)) ? '★' : '☆' %>
                  <% } %>
                </p>
                <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= resena.comentario || 'Sin comentario.' %></p>
              </article>
              <% if (idx < resenasProducto.length - 1) { %>
                <hr class="border-gray-100">
              <% } %>
            <% }) %>
          </div>
          <% if (paginationResenas && paginationResenas.totalPages > 1) { %>
            <div class="mt-6 flex items-center justify-center gap-2">
              <% if (paginationResenas.hasPrev) { %>
                <a
                  href="/cliente/detalle-producto/<%= producto.id_producto %>?page=<%= paginationResenas.prevPage %>#resenas-producto"
                  class="px-3 py-1.5 rounded-md border text-sm font-medium transition-colors bg-white border-gray-300 text-gray-700 hover:bg-gray-50"
                  aria-disabled="false"
                >
                  Anterior
                </a>
              <% } else { %>
                <a
                  href="#"
                  class="px-3 py-1.5 rounded-md border text-sm font-medium transition-colors bg-white border-gray-300 text-gray-700 opacity-50 cursor-not-allowed pointer-events-none"
                  aria-disabled="true"
                >
                  Anterior
                </a>
              <% } %>
              <% paginationResenas.pages.forEach((pageNumber) => { %>
                <% if (pageNumber === paginationResenas.currentPage) { %>
                  <a
                    href="/cliente/detalle-producto/<%= producto.id_producto %>?page=<%= pageNumber %>#resenas-producto"
                    class="px-3 py-1.5 rounded-md border border-[#007185] bg-[#007185] text-sm font-medium text-white transition-colors"
                  >
                    <%= pageNumber %>
                  </a>
                <% } else { %>
                  <a
                    href="/cliente/detalle-producto/<%= producto.id_producto %>?page=<%= pageNumber %>#resenas-producto"
                    class="px-3 py-1.5 rounded-md border border-gray-300 bg-white text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50"
                  >
                    <%= pageNumber %>
                  </a>
                <% } %>
              <% }) %>
              <% if (paginationResenas.hasNext) { %>
                <a
                  href="/cliente/detalle-producto/<%= producto.id_producto %>?page=<%= paginationResenas.nextPage %>#resenas-producto"
                  class="px-3 py-1.5 rounded-md border text-sm font-medium transition-colors bg-white border-gray-300 text-gray-700 hover:bg-gray-50"
                  aria-disabled="false"
                >
                  Siguiente
                </a>
              <% } else { %>
                <a
                  href="#"
                  class="px-3 py-1.5 rounded-md border text-sm font-medium transition-colors bg-white border-gray-300 text-gray-700 opacity-50 cursor-not-allowed pointer-events-none"
                  aria-disabled="true"
                >
                  Siguiente
                </a>
              <% } %>
            </div>
          <% } %>
        <% } %>
      </div>
    <% } %>
  </main>

  <%- include('../partials/footer') %>
  <script src="/js/cliente-productos.js"></script>
</body>
</html>
